{
  "defaultProvider": "rift",
  "defaultModel": "gpt-5.5",
  "defaultThinkingLevel": "medium",
  "enabledModels": [
    "rift/*"
  ],
  "transport": "websocket-cached",
  "npmCommand": [
    "env",
    "NPM_CONFIG_MIN_RELEASE_AGE=0",
    "NPM_CONFIG_ALLOW_GIT=all",
    "NPM_CONFIG_IGNORE_SCRIPTS=false",
    "NPM_CONFIG_ENGINE_STRICT=false",
    "NPM_CONFIG_AUDIT=false",
    "npm"
  ],
  "collapseChangelog": true,
  "enableInstallTelemetry": false,
  "compaction": {
    "enabled": true
  },
  "packages": [
    "npm:pi-extmgr",
    {
      "source": "git:github.com/prateekmedia/pi-hooks",
      "extensions": [
        "-ralph-loop/ralph-loop.ts"
      ]
    },
    "git:github.com/ttttmr/pi-context",
    "git:github.com/edxeth/pi-gpt-config",
    "git:github.com/edxeth/pi-ptc-next",
    "git:github.com/edxeth/pi-tasks",
    "npm:@tomooshi/condensed-milk-pi",
    "npm:@sting8k/pi-vcc",
    "git:github.com/edxeth/pi-better-skills",
    "npm:pi-context-prune",
    "git:github.com/eko24ive/pi-ask",
    "git:github.com/edxeth/pi-subagents",
    "git:github.com/mavam/pi-fancy-footer",
    "npm:pi-formatter",
    "npm:@howaboua/pi-auto-trees",
    "git:github.com/edxeth/pi-ralph-loop"
  ],
  "lastChangelogVersion": "0.74.0",
  "hideThinkingBlock": true,
  "theme": "mocha",
  "gptConfig": {
    "fastMode": false,
    "personality": "claude",
    "verbosity": "low",
    "summary": "auto",
    "showFooter": false,
    "toolDiscipline": "on"
  },
  "quietStartup": true,
  "tasksMode": "all",
  "permissionLevel": "high"
}
